        "module": "commonjs",
        "esModuleInterop": true,
        "target": "es6",
        "strict": true,
        "moduleResolution": "node",
        "ignoreDeprecations": "6.0",
        "sourceMap": true,
        "outDir": "build",
        "rootDir": "./src"
    },
    "include": [
        "./src/**/*"
    ]
}
